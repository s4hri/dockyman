VERSION=v0.0.1
DOCKYMAN_VER=2.2

REGISTRY=iitschri
PROJECT_NAME=null
BASE_PROJECT_NAME=${REGISTRY}/${PROJECT_NAME}
BASE_IMAGE_SRC=alpine:latest # (ubuntu:latest, centos:latest)
BASE_IMAGE_NAME=${BASE_PROJECT_NAME}-docker:${VERSION}

LOCAL_IMAGE_NAME=${BASE_IMAGE_NAME}.local
