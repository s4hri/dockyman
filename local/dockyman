#!/bin/bash
cat << "EOF"

##############################################################

#####    ####    ####   #    #   #   #  #    #    ##    #    #
#    #  #    #  #    #  #   #     # #   ##  ##   #  #   ##   #
#    #  #    #  #       ####       #    # ## #  #    #  # #  #
#    #  #    #  #       #  #       #    #    #  ######  #  # #
#    #  #    #  #    #  #   #      #    #    #  #    #  #   ##
#####    ####    ####   #    #     #    #    #  #    #  #    #

---
Author: Davide De Tommaso, Istituto Italiano di Tecnologia (IIT)
Code: https://github.com/s4hri/dockyman

##############################################################
EOF

# Check the Bash version
echo "Bash version: $BASH_VERSION"

# Check if 'declare' is available
type declare

set -e

display_usage() {
cat << EOF

> QUICK RUN

    1. Download the dockyman template:

        \$ cd myrepo
        \$ docker run -it --network=host iitschri/dockyman --action init --target \${PWD} --username \${USER} --hostname \${HOSTNAME}

    2a. Build & run (Visual Studio Code)

        \$ cd myrepo
        \$ code .
        (...)

    2b. Build & run (make)

        \$ cd myrepo
        \$ make -C .devcontainer
        (...)


> COMMAND-LINE INTERFACE
    
        Usage: dockyman --action <action> [args]
    
        Actions:
            'bash': Launches a bash console inside the docker container.
            'init': Initializes the dockyman environment.
            'build_base': Builds a base Docker image.
            'build_local': Builds a local Docker image.
            'push': Push the base image.
            'clean': Clean both the base and the local image.

        - BASH
                    Usage: dockyman --action bash

                    Description: This action will open a bash console inside the container 
                                 to start working with the command line tools.
        - INIT 
                    Usage: dockyman --action init

                    Description: The dockyman template will be copied into the target folder.
    
        - BUILD BASE: 
                    
                    Usage: dockyman --action build_base
                                    --image_name <image_name>
                                    --workspace_folder <workspace_folder>

                    Description: The program will build a docker image with name <image_name> from
                                 the devcontainer.json placed in /shared/<workspace_folder> inside
                                 the dockyman docker container.

                    Example: dockyman --action build_base
                                      --image_name iitschri/ubuntu
                                      --workspace_folder /


EOF
}

build_base()
{
    echo "DOCKYMAN -> Building BASE image ..."
    if [ -z ${push+x} ]; then push=false; else push=true; fi
    if [ -z ${image_name+x} ]; then echo "Param: image_name is unset"; exit 1; else echo "Param: image_name: '$image_name'"; fi
    if [ -z ${workspace_folder+x} ]; then echo "Param: workspace_folder is unset"; exit 1; else echo "Param: workspace_folder: '$workspace_folder'"; fi
    if [ -z ${push+x} ]; then echo "Param: push is unset"; exit 1; else echo "Param: push: '$push'"; fi
    devcontainer build --image-name $image_name --workspace-folder /shared/$workspace_folder
}


build_local()
{
    echo "DOCKYMAN -> Building LOCAL image ..."
    if [ -z ${image_name+x} ]; then echo "Param: image_name is unset"; exit 1; else echo "Param: image_name: '$image_name'"; fi
    if [ -z ${groups+x} ]; then echo "Param: groups is unset"; exit 1; else echo "Param: groups: '$groups'"; fi
    if [ -z ${username+x} ]; then echo "Param: username is unset"; exit 1; else echo "Param: username: '$username'"; fi
    if [ -z ${uid+x} ]; then echo "Param: uid is unset"; exit 1; else echo "Param: uid: '$uid'"; fi
    if [ -z ${gid+x} ]; then echo "Param: gid is unset"; exit 1; else echo "Param: gid: '$gid'"; fi

    GROUP_IDS=""
    while IFS=',' read -ra ADDR; do
        for i in "${ADDR[@]}"; do
            group_id=$(getent group "$i" | cut -d: -f3)
            if [ ! -z "$group_id" ]; then
                GROUP_IDS="${GROUP_IDS}${group_id},"
            fi
        done
    done <<< "$groups"

    GROUP_IDS=${GROUP_IDS::-1}


    echo "$GROUP_IDS"

    docker build -t $image_name.local --build-arg DOCKER_SRC=$image_name \
                                      --build-arg USERNAME=$username \
                                      --build-arg USER_UID=$uid \
                                      --build-arg USER_GID=$gid \
                                      --build-arg USER_GROUPS=$groups \
                                      --build-arg GROUP_IDS=$GROUP_IDS \
                                      /workdir/local
}

pull()
{
    echo "DOCKYMAN -> Pulling BASE image from Docker registry..."

    if docker pull $image_name; then
        echo "DOCKYMAN -> Pulling BASE image succeed!"
    else
        build_base $image_name $workspace_folder
    fi
}

push()
{
    echo "DOCKYMAN -> Pushing $image_name image ..."
    docker push $image_name
}

clean()
{
    echo "DOCKYMAN -> Removing BASE image ..."
    docker image rmi -f $image_name
    echo "DOCKYMAN -> Removing LOCAL image ..."
    docker image rmi -f $image_name.local
}

init()
{
    echo "DOCKYMAN -> Initializing template ..."
    scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -r /workdir/template/* /workdir/template/.* $username@$hostname:$target
    echo "Initialization finished!"
}

if [[ "$1" == "--help" || "$1" == "help" ]]; then
    display_usage
    exit 0
fi

while [ $# -gt 0 ]; do
    if [[ $1 == *"--"* ]]; then
        v="${1/--/}"
        if [ -n "$2" ] && [[ ! $2 == "--"* ]]; then
            declare "$v=$2"
            shift
        else
            # If the next argument is empty or starts with '--', assign an empty value
            declare "$v="
        fi
    fi
    shift
done

if [ -z "$action" ]; then
    display_usage
    exit 0
elif [ "$action" = "bash" ]; then
    bash
elif [ "$action" = "init" ]; then
    init $target $username $hostname
elif [ "$action" = "build_base" ]; then
    build_base $image_name $workspace_folder
elif [ "$action" = "build_local" ]; then
    build_local $image_name $username $uid $gid $groups
elif [ "$action" = "push" ]; then
    push $image_name
elif [ "$action" = "clean" ]; then
    clean $image_name
fi