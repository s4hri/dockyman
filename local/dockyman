#!/bin/bash

echo "Bash version: $BASH_VERSION"

type declare

set -e

display_usage() {
cat << EOF

> QUICK RUN

    1. Download the template:

        \$ cd myrepo
        \$ docker run -it -v \${PWD}:/shared iitschri/dockyman --action init --own \$(id -u):\$(id -g)

    2a. Build & run (Visual Studio Code)

        \$ cd myrepo
        \$ code .
        (...)

    2b. Build & run (make)

        \$ cd myrepo
        \$ make -C .dockyman
        (...)

    3. Update the core:

            \$ cd myrepo
            \$ docker run -it -v \${PWD}:/shared iitschri/dockyman --action update --own \$(id -u):\$(id -g)

> COMMAND-LINE INTERFACE
    
        Usage: dockyman --action <action> [args]
    
        Actions:
            'bash': Launches a bash console inside the dockyman container.
            'init': Initializes the dockyman environment.
            'update': Update the dockyman core (.dockyman folder)
            'build_base': Builds a base Docker image.
            'build_local': Builds a local Docker image.
            'push': Push the base image.
            'clean': Clean both the base and the local image.

        - BASH
                    Usage: dockyman --action bash

                    Description: This action will open a bash console inside the container 
                                 to start working with the command line tools.
        - INIT 
                    Usage: dockyman --action init
                                    --own <own_ids>

                    Description: The dockyman template will be copied from the dockyman container 
                                 into the target folder of the local machine specified in the volumes.

        - UPDATE 
                    Usage: dockyman --action update
                                    --own <own_ids>

                    Description: The dockyman core (.dockyman folder) will be updated (overwrite)
                                 into the target folder of the local machine specified in the volumes.

        - BUILD BASE: 
                    
                    Usage: dockyman --action build_base
                                    --image_name <image_name>
                                    --workspace_folder <workspace_folder>

                    Description: It will built a docker image named <image_name> based on
                                 the devcontainer.json located in /shared/<workspace_folder> of the 
                                 dockyman container.

        - BUILD LOCAL: 
                    
                    Usage: dockyman --action build_local
                                    --image_name <image_name>
                                    --username <container_username>
                                    --uid <container_uid>
                                    --gid <container_gid>
                                    --groups <container_groups>

                    Description: It will built a docker named <image_name>.local starting from
                                 the image <image_name>. The local image will be configured with
                                 the local settings provided (username, gid, uid, groups). Specifically,
                                 the groups (a coma separated list i.e.: 'sudo,audio,video') are inherited
                                 from the local machine, namely there will be an id correspondance between
                                 the local machine and the container.

        - PUSH: 
                    
                    Usage: dockyman --action push
                                    --image_name <image_name>
                                    ---dockerhubusername <dockerhub_username>
                                    --dockerhubpassword <dockerhub_password>

                    Description: It will push the base docker image named <image_name>.

        - CLEAN: 
                    
                    Usage: dockyman --action clean
                                    --image_name <image_name>

                    Description: It will remove the base docker image named <image_name> and its local 
                                 image <image_name>.local from the local docker repository.

EOF
}

build_base()
{
    echo "DOCKYMAN -> Building BASE image ..."
    if [ -z ${push+x} ]; then push=false; else push=true; fi
    if [ -z ${image_name+x} ]; then echo "Param: image_name is unset"; exit 1; else echo "Param: image_name: '$image_name'"; fi
    if [ -z ${workspace_folder+x} ]; then echo "Param: workspace_folder is unset"; exit 1; else echo "Param: workspace_folder: '$workspace_folder'"; fi
    if [ -z ${push+x} ]; then echo "Param: push is unset"; exit 1; else echo "Param: push: '$push'"; fi
    devcontainer build --image-name $image_name --workspace-folder /shared/$workspace_folder $nocache
}


build_local()
{
    if docker image inspect "$image_name.local" &> /dev/null; then
        echo "Docker image $image_name.local is already present locally."
    else
        echo "DOCKYMAN -> Building LOCAL image ..."
        if [ -z ${image_name+x} ]; then echo "Param: image_name is unset"; exit 1; else echo "Param: image_name: '$image_name'"; fi
        if [ -z ${groups+x} ]; then echo "Param: groups is unset"; exit 1; else echo "Param: groups: '$groups'"; fi
        if [ -z ${username+x} ]; then echo "Param: username is unset"; exit 1; else echo "Param: username: '$username'"; fi
        if [ -z ${uid+x} ]; then echo "Param: uid is unset"; exit 1; else echo "Param: uid: '$uid'"; fi
        if [ -z ${gid+x} ]; then echo "Param: gid is unset"; exit 1; else echo "Param: gid: '$gid'"; fi

        GROUP_IDS=""
        while IFS=',' read -ra ADDR; do
            for i in "${ADDR[@]}"; do
                group_id=$(getent group "$i" | cut -d: -f3)
                if [ ! -z "$group_id" ]; then
                    GROUP_IDS="${GROUP_IDS}${group_id},"
                fi
            done
        done <<< "$groups"

        GROUP_IDS=${GROUP_IDS::-1}


        echo "$GROUP_IDS"

        docker build -t $image_name.local --build-arg DOCKER_SRC=$image_name \
                                          --build-arg USERNAME=$username \
                                          --build-arg USER_UID=$uid \
                                          --build-arg USER_GID=$gid \
                                          --build-arg USER_GROUPS=$groups \
                                          --build-arg GROUP_IDS=$GROUP_IDS \
                                          /workdir/local  
    fi
}

pull()
{
    if docker image inspect "$image_name" &> /dev/null; then
        echo "Docker image $image_name is already present locally."
    else
        if docker pull "$image_name" &> /dev/null; then
            echo "Pulled Docker image $image_name."
        else
            build_base $image_name $workspace_folder
        fi
    fi
}

push()
{
    echo "DOCKYMAN -> Pushing $image_name image ..."
    echo $dockerhubpassword | docker login --username $dockerhubusername --password-stdin
    docker push $image_name
}

clean_base()
{
    echo "DOCKYMAN -> Removing BASE image ..."
    docker image rmi -f $image_name
}

clean()
{
    clean_base
    echo "DOCKYMAN -> Removing LOCAL image ..."
    docker image rmi -f $image_name.local
}

init()
{
    echo "DOCKYMAN -> Initializing template ..."
    rsync -av /workdir/template/ /shared/
    chown -R $own /shared
    echo "Initialization finished!"
}

update()
{
    echo "DOCKYMAN -> Updating template ..."
    source_dir="/workdir/template"
    dest_dir="/shared"

    # Function to sync files and directories
    sync_item() {
        local item="$1"
        local dest="$2"

        # Extract item name without the full path
        item_name=$(basename "$item")

        # Check if the item exists in the destination directory
        if [ -e "$dest/$item_name" ]; then
            # Check if the item is a directory
            if [ -d "$item" ]; then
                # Sync the directory if it's different
                if ! diff -q -r "$item" "$dest/$item_name" >/dev/null; then
                    read -p "Do you want to update <$item_name> directory? (y/N) " choice
                    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
                        rsync -av "$item" "$dest"
                        echo "Updated <$item_name> directory"
                    else
                        echo "Skipped <$item_name> directory (user choice)"
                    fi
                else
                    echo "Skipped <$item_name> directory (contents are the same)"
                fi
            elif [ -f "$item" ]; then
                # Sync the file if it's different
                if ! diff -q "$item" "$dest/$item_name" >/dev/null; then
                    read -p "Do you want to update <$item_name> file? (y/N) " choice
                    if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
                        rsync -av "$item" "$dest"
                        echo "Updated <$item_name> file"
                    else
                        echo "Skipped <$item_name> file (user choice)"
                    fi
                else
                    echo "Skipped <$item_name> file (contents are the same)"
                fi
            fi
        else
            # Item doesn't exist in the destination directory, so sync it
            read -p "Do you want to copy <$item_name>? (y/N) " choice
            if [ "$choice" = "y" ] || [ "$choice" = "Y" ]; then
                rsync -av "$item" "$dest"
                echo "Copied <$item_name>"
            else
                echo "Skipped <$item_name> (user choice)"
            fi
        fi
    }

    # Loop through each item in the source directory, including hidden items
    for item in "$source_dir"/* "$source_dir"/.*; do
        # Skip special entries (., .., .hidden, etc.)
        if [ "$(basename "$item")" != "." ] && [ "$(basename "$item")" != ".." ]; then
            # Sync each item and prompt for confirmation
            sync_item "$item" "$dest_dir"
        fi
    done
    chown -R $own /shared
    echo "Update finished!"
}

if [[ "$1" == "--help" || "$1" == "help" ]]; then
    display_usage
    exit 0
fi

while [ $# -gt 0 ]; do
    if [[ $1 == *"--"* ]]; then
        v="${1/--/}"
        if [ -n "$2" ] && [[ ! $2 == "--"* ]]; then
            declare "$v=$2"
            shift
        else
            # If the next argument is empty or starts with '--', assign an empty value
            declare "$v="
        fi
    fi
    shift
done

if [ -z "$action" ]; then
    display_usage
    exit 0
elif [ "$action" = "bash" ]; then
    bash
elif [ "$action" = "init" ]; then
    init $own
elif [ "$action" = "update" ]; then
    update $own
elif [ "$action" = "build_base_nocache" ]; then
    nocache="--no-cache"
    build_base $image_name $workspace_folder $nocache
elif [ "$action" = "build_base" ]; then
    pull $image_name $workspace_folder
elif [ "$action" = "build_local" ]; then
    build_local $image_name $username $uid $gid $groups
elif [ "$action" = "pull" ]; then
    pull $image_name $workspace_folder
elif [ "$action" = "push" ]; then
    push $image_name $dockerhubusername $dockerhubpassword
elif [ "$action" = "clean_base" ]; then
    clean_base $image_name
elif [ "$action" = "clean" ]; then
    clean $image_name
fi